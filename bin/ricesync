#!/bin/bash

# Ensure we are in home directory to resolve relative paths correctly
cd "$HOME" || exit 1

# Create directories in rice repo
mkdir -p rice/hypr rice/kitty rice/tofi rice/waybar rice/fish rice/fastfetch rice/foot rice/ghostty rice/wob rice/quickshell rice/bin rice/nano

# Files and directories to watch
# Note: we explicitly track custom scripts in .local/bin, avoiding large binaries
find .config/hypr .config/kitty .config/tofi .config/waybar .config/fish .config/fastfetch .config/foot .config/ghostty .config/wob .config/quickshell .nanorc .local/bin/amd_s2idle.py .local/bin/battery_mode.sh .local/bin/notify .local/bin/ricesync -type f | \
entr -r bash -c '
    echo "Syncing configurations..."
    rsync -aq --delete .config/hypr/ rice/hypr/
    rsync -aq --delete .config/kitty/ rice/kitty/
    rsync -aq --delete .config/tofi/ rice/tofi/
    rsync -aq --delete .config/waybar/ rice/waybar/
    rsync -aq --delete .config/fish/ rice/fish/
    rsync -aq --delete .config/fastfetch/ rice/fastfetch/
    rsync -aq --delete .config/foot/ rice/foot/
    rsync -aq --delete .config/ghostty/ rice/ghostty/
    rsync -aq --delete .config/wob/ rice/wob/
    rsync -aq --delete .config/quickshell/ rice/quickshell/
    cp ~/.nanorc rice/nano/nanorc
    
    # Sync specific scripts
    cp ~/.local/bin/amd_s2idle.py rice/bin/
    cp ~/.local/bin/battery_mode.sh rice/bin/
    cp ~/.local/bin/notify rice/bin/
    cp ~/.local/bin/ricesync rice/bin/
    
    # Only copy README if it exists in obsidian
    if [ -f ~/obsidian_vault/op13/archlinux.md ]; then
        cp ~/obsidian_vault/op13/archlinux.md rice/README.md
    fi
    echo "rice aggiornata!"
'