# Ghostty Configuration (Migrated from Kitty)

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Window
background-opacity = 0.7
window-padding-x = 10
window-padding-y = 10

# Cursor
cursor-style-blink = false

# Other
shell-integration = fish
confirm-close-surface = false

# Theme (Managed by switch_theme.sh)
config-file = theme
